# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-in-production
DEBUG=True

# Database
POSTGRES_DB=omnifreight
POSTGRES_USER=omnifreight
POSTGRES_PASSWORD=omnifreight
DATABASE_URL=postgres://omnifreight:omnifreight@db:5432/omnifreight

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# CORS — comma-separated origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email (dev: console backend; prod: SendGrid)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
SENDGRID_API_KEY=

# AWS S3 (leave blank in dev to use local filesystem)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
